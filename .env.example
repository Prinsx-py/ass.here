# ============================================================================
# ass.here Configuration
# ============================================================================
#
# This file contains environment variables for the ass.here API.
# Copy this to .env and fill in the values below.
# NEVER commit .env to version control — it contains secrets.
#

# --- SUPABASE (Database & Storage) ---
# Required for API functionality

# Your Supabase project URL
# Found at: https://app.supabase.com/project/[PROJECT_ID]/settings/api
SUPABASE_URL=https://YOUR_SUPABASE_PROJECT.supabase.co

# Your Supabase service role key (keep this secret!)
# Found at: https://app.supabase.com/project/[PROJECT_ID]/settings/api
# Use the "service_role" key, NOT the public "anon" key
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY

# Storage bucket name for uploaded .ass files
# Default: ass-files
SUPABASE_BUCKET=ass-files

# --- LOCAL DEVELOPMENT ---

# Port for local development server (used by `vercel dev`)
# Default: 3000
PORT=3000

# --- CLIENT CONFIGURATION (Browser/Client-side) ---
# These are used by the frontend to find the API.
# They override the default 'https://ass.here' domain.

# Override the API base URL for clients
# Use this if your API is deployed to a different domain
# Example values:
#   - https://api.example.com
#   - https://my-custom-domain.vercel.app
#   - http://localhost:3000 (for local development)
#
# If not set, clients default to: https://ass.here
# Clients can also set this via ASS_HERE_API_BASE environment variable
# or by calling apiConfig.setApiBase(url) in browser
ASS_HERE_API_BASE=

# Request timeout for API calls (milliseconds)
# Default: 10000 (10 seconds)
# Increase if you have slow network or large files
ASS_HERE_TIMEOUT=10000

# Number of retries when API calls fail
# Default: 2
# Increases resilience for flaky networks
ASS_HERE_RETRY_COUNT=2

# --- DEPLOYMENT & HOSTING ---

# If deploying to Vercel:
# 1. Set SUPABASE_URL and SUPABASE_SERVICE_KEY in Vercel Environment Variables
# 2. Configure your domain (e.g., ass.here) in Vercel Project Settings
# 3. Ensure DNS records point to Vercel (see HOSTING.md)

# If deploying elsewhere:
# 1. Update ASS_HERE_API_BASE to your deployment URL
# 2. Ensure clients can reach your API endpoint
# 3. Verify HTTPS is working (if using https://)
# 4. Check firewall rules if requests are blocked
